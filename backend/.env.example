NODE_ENV=development
PORT=4000

JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=courier_db
DB_USER=root
DB_PASS=

# Development DB choice.
# Use `mysql` in production, and optionally `sqlite` for local testing.
DB_DIALECT=mysql
SQLITE_STORAGE=./dev.sqlite

# For local development only. In production, use migrations.
DB_SYNC=true

# Frontend URL (Vite dev server)
CORS_ORIGIN=http://localhost:5173

