NODE_ENV=development
PORT=4000

JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d

# Short-lived secret for password-reset tokens (15 min)
RESET_SECRET=reset-secret-change-me-in-prod
RESET_EXPIRES_IN=15m

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=courier_db
DB_USER=root
DB_PASS=

# For local development only. In production, use migrations.
DB_SYNC=true

# Use sqlite for local end-to-end testing when MySQL isn't running.
DB_DIALECT=sqlite
SQLITE_STORAGE=./dev.sqlite

# Frontend URL (used in reset-password email link)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# SMTP (leave blank to use dev console-log mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@couriernepal.com

